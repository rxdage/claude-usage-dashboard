{
  "name": "claude-usage-dashboard",
  "version": "1.9.5",
  "description": "A floating desktop widget showing Claude Code and ChatGPT/Codex Desktop plan usage in real time — 100% local.",
  "main": "main.js",
  "author": "rxdage",
  "repository": {
    "type": "git",
    "url": "https://github.com/rxdage/claude-usage-dashboard.git"
  },
  "scripts": {
    "start": "electron .",
    "cal": "node calibrate.js",
    "test": "node --test",
    "dist": "electron-builder"
  },
  "keywords": [
    "claude",
    "claude-code",
    "chatgpt-desktop",
    "codex-desktop",
    "chatgpt-plan",
    "usage",
    "dashboard",
    "widget",
    "electron",
    "tachometer",
    "token-usage"
  ],
  "license": "SEE LICENSE IN LICENSE",
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.rxdage.claude-usage-dashboard",
    "productName": "Claude Usage Dashboard",
    "files": [
      "main.js",
      "preload.js",
      "usage.js",
      "calibrate.js",
      "providers.js",
      "providers/**",
      "renderer/**",
      "assets/**"
    ],
    "asarUnpack": [
      "assets/**"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "rxdage",
        "repo": "claude-usage-dashboard"
      }
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "assets/icon.ico",
      "artifactName": "${productName}-${version}-${arch}-setup.${ext}"
    },
    "portable": {
      "artifactName": "${productName}-${version}-${arch}-portable.${ext}"
    },
    "nsis": {
      "include": "build/installer.nsh",
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "${productName}-${version}-${arch}-setup.${ext}"
    }
  }
}
